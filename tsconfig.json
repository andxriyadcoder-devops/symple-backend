{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,

    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,

    "moduleResolution": "node",

    "resolveJsonModule": true,

    "allowSyntheticDefaultImports": true,

    "types": ["node"],

    "baseUrl": "./src",

    "paths": {
      "@/*": ["*"]
    }
  },

  "include": ["src"],

  "exclude": ["node_modules", "dist"]
}